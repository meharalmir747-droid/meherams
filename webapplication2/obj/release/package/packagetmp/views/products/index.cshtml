@model IEnumerable<WebApplication2.Models.Product>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layoutadmin.cshtml";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Product_name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Product_salePrice)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Product_purchasePrice)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Product_Pic)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Cat_ForeignID)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Product_name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Product_salePrice)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Product_purchasePrice)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Product_Pic)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Cat_ForeignID)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Product_ID }) |
            @Html.ActionLink("Details", "Details", new { id=item.Product_ID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Product_ID })
        </td>
    </tr>
}

</table>
